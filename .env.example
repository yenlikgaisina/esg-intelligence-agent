# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Tavily web-search API key (free tier available) — https://tavily.com/
TAVILY_API_KEY=tvly-...

# ---- Optional overrides ----
# ESG_MODEL=claude-sonnet-4-6        # use claude-opus-4-8 for deeper analysis
# ESG_FOCUS_REGION=Kazakhstan + global
# ESG_MAX_STEPS=30
